#include <stdio.h>
 
int main() {
   
    int t;
    scanf("%d",&t);
 
    while (t--)
    {   
        int blank_Space, count=0, max=0;
        int n;
        scanf("%d",&n);
        int arr[n];
 
        for (int i=0; i<n; i++)
        {
            scanf("%d", &arr[i]);
 
            if (arr[i]==0)
            {
                count++;
            }
            else
            {
                count=0;
            }
 
            if (count>max)
            {
                max=count;
            }
        }
 
        printf("%d\n",max);
 
    }
 
    return 0;
}
