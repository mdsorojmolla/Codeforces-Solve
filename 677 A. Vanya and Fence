#include <stdio.h>
int main() {
    
    int n, h, a, sum=0;
    scanf("%d %d", &n, &h);
 
    while (n--)
    {
        scanf("%d",&a);
 
        if (a<=h)
        {
            sum+=1;
        }
 
        else
        {
            sum+=2;
        }
    }
 
    printf("%d\n", sum);
 
    return 0;
}
